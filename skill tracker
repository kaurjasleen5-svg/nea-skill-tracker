#function for loading the registration frame
def load_registrationframe():
    #function for registering a new user
    def register_user(username_entry, password_entry, confirm_entry, role_var):
        from tkinter import messagebox

        username = username_entry.get()
        password = password_entry.get()
        confirm_password = confirm_entry.get()
        role = role_var.get()

        #checking if passwords match
        if password != confirm_password:
            messagebox.showerror("Error", "Passwords do not match")
            return

        #checking if a role has been selected
        if role == "":
            messagebox.showerror("Error", "Please select a role")
            return

        #creating a random user ID
        import random
        user_id = random.randint(10000, 99999)

        #inserting user into correct table based on role
        try:
            if role == "coach":
                cursor.execute("INSERT INTO COACH (coach_ID, coach_name, coach_username, coach_password, coach_specialisation) VALUES (?, ?, ?, ?, ?)",
                               (user_id, username, username, password, None))

            elif role == "student":
                cursor.execute("INSERT INTO PUPIL (pupil_ID, pupil_name, pupil_username, pupil_password) VALUES (?, ?, ?, ?)",
                               (user_id, username, username, password))

            connection.commit()
            messagebox.showinfo("Success", "User successfully registered")

        except Exception as e:
            messagebox.showerror("Error", f"An error occurred: {e}")

    
    #creating register title
    register_label = tk.Label(
        registerframe,
        text="Register",
        font=("Arial", 26, "bold"),
        bg="white")
    register_label.pack(pady=(20, 10))

    #creating username label and entry box
    username_label = tk.Label(
        registerframe,
        text="Username",
        font=("Arial", 12),
        bg="white")
    username_label.pack()
    username_entry = tk.Entry(
        registerframe,
        font=("Arial", 16))
    username_entry.pack(pady=5)

    #creating password label and entry box
    password_label = tk.Label(
        registerframe,
        text="Password",
        font=("Arial", 12),
        bg="white")
    password_label.pack()
    password_entry = tk.Entry(
        registerframe,
        show="*",
        font=("Arial", 16))
    password_entry.pack(pady=5)

    #creating confirm password label and entry box
    confirm_label = tk.Label(
        registerframe,
        text="Confirm Password",
        font=("Arial", 12),
        bg="white")
    confirm_label.pack()
    confirm_entry = tk.Entry(
        registerframe,
        show="*",
        font=("Arial", 16))
    confirm_entry.pack(pady=5)

    #creating role selection label
    role_label = tk.Label(
        registerframe,
        text="Select Role",
        font=("Arial", 12),
        bg="white")
    role_label.pack(pady=(10, 5))

    #creating buttons for selecting role
    role_var = tk.StringVar()
    role_frame = tk.Frame(registerframe, bg="white")
    role_frame.pack()

    coach_radio = tk.Radiobutton(
        role_frame,
        text="Coach",
        variable=role_var,
        value="coach",
        font=("Arial", 12),
        bg="white")
    coach_radio.pack(side="left", padx=10)

    pupil_radio = tk.Radiobutton(
        role_frame,
        text="Student",
        variable=role_var,
        value="student",
        font=("Arial", 12),
        bg="white")
    pupil_radio.pack(side="left", padx=10)

    #creating the register button
    register_btn = tk.Button(
        registerframe,
        text="Register",
        width=10,
        height=1,
        font=("Arial", 12),
        cursor="hand2",
        command=lambda: register_user(username_entry, password_entry, confirm_entry, role_var)
    )
    register_btn.pack(pady=20)

    #creating the back button and ensuring that when the button is pressed the program navigates the user back to the homeframe
    back_btn = tk.Button(
        registerframe,
        text="Back",
        width=10,
        height=1,
        font=("Arial", 12),
        cursor="hand2",
        command=lambda: show_frame(homeframe)
    )
    back_btn.pack(pady=10)



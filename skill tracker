import tkinter as tk
from PIL import ImageTk, Image
import sqlite3
    
#function for ensuring that all frames are centered when they pop up on user's desktop
def center_window(win,width,height):
    screen_w=win.winfo_screenwidth()
    screen_h=win.winfo_screenheight()
    x = (screen_w//2)-(width//2)
    y = (screen_h//2)-(height//2)
    win.geometry(f"{width}x{height}+{x}+{y}")

#function for allowing navigation between frames when certain buttons are pressed
def show_frame(frame):
    frame.tkraise()

#creating the main window
root = tk.Tk()
root.title("Skill Tracker")
center_window(root, 1024, 768)

